{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Module map",
  "type": "object",
  "required": ["summary", "modules"],
  "properties": {
    "summary": { "type": "string", "minLength": 10 },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "purpose", "ir_roots", "estimated_size", "priority"],
        "properties": {
          "id": { "type": "string", "pattern": "^MOD-[A-Z0-9-]+$" },
          "title": { "type": "string", "minLength": 3 },
          "purpose": { "type": "string", "minLength": 10 },
          "ir_roots": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "ir_slices": { "type": "array", "items": { "type": "string" } },
          "estimated_size": { "type": "string", "enum": ["small", "medium", "large"] },
          "priority": { "type": "number" },
          "decompose_depends_on": {
            "type": "array",
            "items": { "type": "string", "pattern": "^MOD-[A-Z0-9-]+$" }
          }
        }
      }
    }
  }
}
