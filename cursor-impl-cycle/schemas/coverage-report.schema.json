{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Coverage report",
  "type": "object",
  "required": ["item_id", "module_id", "assessed_at", "coverage_pct", "criteria"],
  "properties": {
    "item_id": { "type": "string", "minLength": 3 },
    "module_id": { "type": "string", "pattern": "^MOD-[A-Z0-9-]+$" },
    "assessed_at": { "type": "string" },
    "coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "partial", "fail", "na"] },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "gap": { "type": "string" }
        }
      }
    },
    "files_changed": { "type": "array", "items": { "type": "string" } }
  }
}
