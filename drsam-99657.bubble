r":2},"bTHhU":{"display":"Somewhat aligned — some things fit, others feel off","index":3,"db_value":"somewhat_aligned___some_things_fit__others_feel_off","question":"how_aligned_do_your_daily_actions_feel_with_your_core_values_right_now_","sort_factor":3},"bTHhV":{"display":"Mostly aligned — my life generally reflects my values","index":4,"db_value":"mostly_aligned___my_life_generally_reflects_my_values","question":"how_aligned_do_your_daily_actions_feel_with_your_core_values_right_now_","sort_factor":4},"bTHhW":{"display":"Fully aligned — how I live reflects who I am and what I believe","index":5,"db_value":"fully_aligned___how_i_live_reflects_who_i_am_and_what_i_believe","question":"how_aligned_do_your_daily_actions_feel_with_your_core_values_right_now_","sort_factor":5},"bTHha":{"display":"|","deleted":true,"db_value":"_","sort_factor":6},"bTHhb":{"display":"Not sustainable — I have no real structure and it's catching up with me","index":1,"db_value":"not_sustainable___i_have_no_real_structure_and_it_s_catching_up_with_me","question":"how_sustainable_are_your_current_daily_habits_and_routines_","sort_factor":7},"bTHhc":{"display":"Barely — I have some routines but they're fragile","index":2,"db_value":"barely___i_have_some_routines_but_they_re_fragile","question":"how_sustainable_are_your_current_daily_habits_and_routines_","sort_factor":8},"bTHhg":{"display":"Somewhat — I have a foundation but need more consistency","index":3,"db_value":"somewhat___i_have_a_foundation_but_need_more_consistency","question":"how_sustainable_are_your_current_daily_habits_and_routines_","sort_factor":9},"bTHhh":{"display":"Mostly sustainable — my habits generally support me","index":4,"db_value":"mostly_sustainable___my_habits_generally_support_me","question":"how_sustainable_are_your_current_daily_habits_and_routines_","sort_factor":10},"bTHhi":{"display":"Very sustainable — my routines are solid and serve me well","index":5,"db_value":"very_sustainable___my_routines_are_solid_and_