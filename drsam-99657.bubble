ue":"very_consistent___i_am_actively_and_intentionally_engaged_every_day","question":"how_consistent_are_you_at_engaging_with_the_things_that_matter_most_to_you_","sort_factor":135},"bTHeW":{"display":"|","deleted":true,"db_value":"_24","sort_factor":136},"bTHea":{"display":"Not effective — this phase feels like it's happening to me","index":1,"db_value":"not_effective___this_phase_feels_like_it_s_happening_to_me","question":"how_effective_do_you_feel_at_shaping_this_chapter_of_your_life_","sort_factor":137},"bTHeb":{"display":"Below where I'd like — I'm not making it what I hoped","index":2,"db_value":"below_where_i_d_like___i_m_not_making_it_what_i_hoped","question":"how_effective_do_you_feel_at_shaping_this_chapter_of_your_life_","sort_factor":138},"bTHec":{"display":"Somewhat effective — there are good parts but I'm not fully there","index":3,"db_value":"somewhat_effective___there_are_good_parts_but_i_m_not_fully_there","question":"how_effective_do_you_feel_at_shaping_this_chapter_of_your_life_","sort_factor":139},"bTHeg":{"display":"Effective — I'm creating a life I generally feel good about","index":4,"db_value":"effective___i_m_creating_a_life_i_generally_feel_good_about","question":"how_effective_do_you_feel_at_shaping_this_chapter_of_your_life_","sort_factor":140},"bTHeh":{"display":"Highly effective — I'm living this phase with intention and satisfaction","index":5,"db_value":"highly_effective___i_m_living_this_phase_with_intention_and_satisfaction","question":"how_effective_do_you_feel_at_shaping_this_chapter_of_your_life_","sort_factor":141},"bTHei":{"display":"|","deleted":true,"db_value":"_25","sort_factor":142},"bTHem":{"display":"Almost never — most days feel empty or unstructured","index":1,"db_value":"almost_never___most_days_feel_empty_or_unstructured","question":"how_often_does_your_time_feel_well_spent_and_meaningful_","sort_factor":143},"bTHen":{"display":"Rarely — I'm filling time more than living it","index":2,"db_value":"rarely___i_m_filling_time_more_than_living_it","question":"how_often_does_your_time_feel_well_spent_and_meaningful_","sort_factor":144},"bTHeo":{"display":"Sometimes — meaningful moments exist but aren't consistent","index":3,"db_value":"sometimes___meaningful_moments_exist_but_aren_t_consistent","question":"how_often_does_your_time_feel_well_spent_and_meaningful_","sort_factor":145},"bTHes":{"display":"Often — most days feel worthwhile","index":4,"db_value":"often___most_days_feel_worthwhile","question":"how_often_does_your_time_feel_well_spent_and_meaningful_","sort_factor":146},"bTHet":{"display":"Consistently — I feel genuinely good about how I spend my time","index":5,"db_value":"consistently___i_feel_genuinely_good_about_how_i_spend_my_time","question":"how_often_does_your_time_feel_well_spent_and_meaningful_","sort_factor":147},"bTHeu":{"display":"|","deleted":true,"db_value":"_26","sort_factor":148},"bTHey":{"display":"Very low — I feel diminished or without purpose","index":1,"db_value":"very_low___i_feel_diminished_or_without_purpose","question":"how_would_you_describe_your_sense_of_confidence_and_capability_in_this_phase_","sort_factor":149},"bTHez":{"display":"Low — I'm questioning my relevance and capability more than I'd like","index":2,"db_value":"low___i_m_questioning_my_relevance_and_capability_more_than_i_d_like","question":"how_would_you_describe_your_sense_of_confidence_and_capability_in_this_phase_","sort_factor":150},"bTHfA":{"display":"Moderate — confident in some areas, uncertain about others","index":3,"db_value":"moderate___confident_in_some_areas__uncertain_about_others","question":"how_would_you_describe_your_sense_of_confidence_and_capability_in_this_phase_","sort_factor":151},"bTHfE":{"display":"Good — I generally feel capable and valuable","index":4,"db_value":"good___i_generally_feel_capable_and_valuable","question":"how_would_you_describe_your_sense_of_confidence_and_capability_in_this_phase_","sort_factor":152},"bTHfF":{"display":"Strong — I bring real experience and confidence to this chapter","index":5,"db_value":"strong___i_bring_real_experience_and_confidence_to_this_chapter","question":"how_would_you_describe_your_sense_of_confidence_and_capability_in_this_phase_","sort_factor":153}},"display":"Customer Performance Answer OS","attributes":{"index":{"display":"index","value":"number","creation_source":"editor"},"question":{"display":"question","value":"option.customer_performance_question_os","creation_source":"editor"}},"creation_source":"editor"},"tier_os":{"display":"Tier OS","values":{"bTIrS":{"display":"free","db_value":"free","priority":0,"sort_factor":1},"bTIrT":{"display":"pro","db_value":"pro","priority":1,"sort_factor":2},"bTIrU":{"display":"premium","db_value":"premium","priority":2,"sort_factor":3}},"attributes":{"priority":{"display":"priority","value":"number","creation_source":"editor"}},"creation_source":"editor"},"load_type_os":{"display":"Load Type OS","values":{"bTIBs":{"display":"cognitive","db_value":"cognitive","sort_factor":1,"high_intensity_text":"Cognitive Overload"},"bTIBw":{"display":"relational","db_value":"relational","sort_factor":2,"high_intensity_text":"Relational Strain"},"bTIBx":{"display":"evironmental","db_value":"evironmental","sort_factor":3,"high_intensity_text":"Logistical Overwhelm"},"bTIBy":{"display":"financial","db_value":"financial","sort_factor":4,"high_intensity_text":"Financial Stress"}},"attributes":{"high_intensity_text":{"display":"high_intensity_text","value":"text","creation_source":"editor"}},"creation_source":"editor"},"pressure_reach":{"display":"Pressure Reach OS","values":{"bTIPw":{"display":"faith","db_value":"bTIPM","sort_factor":1},"bTIQA":{"display":"people","db_value":"bTIPN","sort_factor":2},"bTIQB":{"display":"work","db_value":"bTIPO","sort_factor":3},"bTIQC":{"display":"substances","db_value":"bTIPP","sort_factor":4},"bTIQG":{"display":"avoidance","db_value":"bTIPQ","sort_factor":5},"bTIQH":{"display":"solitude","db_value":"bTIPR","sort_factor":6}}},"belonging_level":{"display":"Belonging Level OS","values":{"bTIPp":{"display":"strong","db_value":"bTIPI","sort_factor":1},"bTIPq":{"display":"moderate","db_value":"bTIPJ","sort_factor":2},"bTIPu":{"display":"weak","db_value":"bTIPK","sort_factor":3},"bTIPv":{"display":"absent","db_value":"bTIPL","sort_factor":4}}},"purpose_clarity":{"display":"Purpose Clarity OS","values":{"bTIPX":{"display":"clear","db_value":"bTIOX","sort_factor":1},"bTIPY":{"display":"searching","db_value":"bTIOY","sort_factor":2},"bTIPc":{"display":"lost","db_value":"bTIOZ","sort_factor":3},"bTIPd":{"display":"rebuilding","db_value":"bTIPA","sort_factor":4}}},"settings_tab_os":{"display":"Settings Tab OS","values":{"bTIiw":{"display":"profile","db_value":"profile","sort_factor":1},"bTIix":{"display":"coaching_preferences","db_value":"coaching_preferences","sort_factor":2},"bTIiy":{"display":"privacy","db_value":"privacy","sort_factor":3},"bTIjC":{"display":"security","db_value":"security","sort_factor":4},"bTIjD":{"display":"workplace","db_value":"workplace","sort_factor":5},"bTIjE":{"display":"notifications","db_value":"notifications","sort_factor":6},"bTIjI":{"display":"subscription","db_value":"subscription","sort_factor":7},"bTIjJ":{"display":"admin","db_value":"admin","sort_factor":8}},"creation_source":"editor"},"customer_role_os":{"display":"Customer Role OS","values":{"bTHKW":{"display":"pro","description":"Employed, running a business, or in a leadership role","db_value":"pro","card_label":"Working professional or leader","sort_factor":1},"bTHKX":{"display":"student","description":"In school, university, or a training program","db_value":"student","card_label":"Student","sort_factor":2},"bTHKY":{"display":"caregiver","description":"Primary caregiver for children, family members, or household","db_value":"caregiver","card_label":"Caregiver or stay-at-home parent","sort_factor":3},"bTHKc":{"display":"transition","description":"Job searching, career changing, or in a period of change","db_value":"transition","card_label":"Between jobs or in transition","sort_factor":4},"bTHKd":{"display":"retired","description":"No longer working full time by choice or circumstance","db_value":"retired","card_label":"Retired or semi-retired","sort_factor":5}},"attributes":{"description":{"display":"description","value":"text","creation_source":"editor"},"card_label":{"display":"card_label","value":"text","creation_source":"editor"}},"creation_source":"editor"},"grief_load_level":{"display":"Grief Load Level OS","values":{"bTIOE":{"display":"low","db_value":"bTINM","sort_factor":1},"bTIOI":{"display":"moderate","db_value":"bTINN","sort_factor":2},"bTIOJ":{"display":"high","db_value":"bTINO","sort_factor":3},"bTIOK":{"display":"unsure","db_value":"bTINP","sort_factor":4}}},"path_page_tab_os":{"display":"Path Page Tab OS","values":{"bTIsz":{"display":"My Paths","db_value":"my_paths_","sort_factor":1},"bTItA":{"display":"Paths Library","db_value":"paths_library","sort_factor":2}},"creation_source":"editor"},"body_relationship":{"display":"Body Relationship OS","values":{"bTIPK":{"display":"connected","db_value":"bTIOQ","sort_factor":1},"bTIPL":{"display":"neutral","db_value":"bTIOR","sort_factor":2},"bTIPM":{"display":"disconnected","db_value":"bTIOS","sort_factor":3},"bTIPQ":{"display":"conflicted","db_value":"bTIOT","sort_factor":4}}},"classification_os":{"display":"Classification OS","values":{"bTHym":{"display":"High Output / Hidden Instability","description":"You're producing at a high level — but your internal stability isn't keeping pace with your output. This is one of the most common and most overlooked patterns. The goal isn't to slow down. It's to make your performance sustainable.","prompt":"This person's classification is High Output / Hidden Instability. They are producing at a high level externally while their internal stability is critically low. This is one of the most common and most overlooked patterns. The pattern you are working with: a high performer whose output is real and whose internal state is not keeping pace with it. They may not recognize the gap themselves — or they may know it and be afraid to slow down. The coaching priority is sustainability. The goal is not to stop them from performing. The goal is to make the performance survivable long term. What this person most needs from you: honesty. Not confrontation, but clarity. They are used to people celebrating their output. They need someone who can hold both things at once — the real achievement and the real cost. The tradeoff statement for this user is: [TRADEOFF_STATEMENT]. This is worth surfacing when the timing is right. It should land as recognition, not accusation. \"What you've built is real — and it's costing you something you haven't fully named yet\" is the spirit. Watch for: deflection through productivity, minimizing emotional signals as weakness, and difficulty slowing down even in a coaching session. These are data. Use them gently.","db_value":"high_output___hidden_instability","sort_factor":1,"coaching_priority":"Performance sustainability — check before Rule 2","tradeoff_statement":"Your performance is being funded by your stability. Output is high — but the internal cost is rising."},"bTHyq":{"display":"Capacity Erosion","description":"Your internal capacity is being stretched beyond what's sustainable right now. This isn't a character flaw — it's a system under load. The first priority is stabilization, not optimization.","prompt":"This person's classification is Capacity Erosion. Their internal capacity is being stretched beyond what is sustainable. This is not a character issue. It is a system under load. The pattern you are working with: a person who is trying to function normally under conditions that are genuinely unsustainable. They may present as managing, as struggling, or as barely holding on — but the underlying reality is the same. The system is running a deficit. The coaching priority is stabilization. Not optimization. Not growth. Not clarity on goals. Stability first, everything else later. What this person most needs from you: to feel that someone sees what they are actually carrying, without judgment, without urgency, and without rushing them toward a solution. Being heard without being fixed is often the most stabilizing thing you can offer. Watch for: a tendency to minimize their own situation, to focus on what they should be doing rather than what they can actually sustain, or to be harder on themselves than the circumstances warrant. Gently challenge this without dismissing it. The behavioral fingerprint for this user is: [BEHAVIORAL_FINGERPRINT]. Factor this into how you approach the session — particularly in how you frame forward motion when the time is right.","db_value":"capacity_erosion","sort_factor":2,"coaching_priority":"Stabilization before everything else","tradeoff_statement":"Right now, functioning is the goal. Growth costs energy you don't currently have to spend."},"bTHyr":{"display":"Performance Stagnation","description":"You have capability — but something is blocking your ability to execute consistently right now. Whether it's clarity, confidence, or follow-through, the coaching will meet you where the gap actually is.","prompt":"This person's classification is Performance Stagnation. The capability is real. Something is blocking consistent execution. The pattern you are working with: a person who knows what they want to do and is not doing it. The gap lives somewhere between intention and action — in clarity, confidence, follow-through, or the belief that it is actually possible. The coaching priority is activation. Not motivation — that is surface-level and temporary. Activation means identifying and removing the actual blocker between knowing and doing. What this person most needs from you: specificity. Generic encouragement will not move them. Helping them get precise about where exactly the execution breaks down will. \"Where does it go off track — is it the starting, the middle, or the finishing?\" is the right kind of question. The behavioral fingerprint for this user is: [BEHAVIORAL_FINGERPRINT]. This is especially important here — the fingerprint tells you exactly where and how execution breaks down for this specific person. Watch for: vague answers about why things aren't happening, intellectualizing the problem without committing to a solution, and confusion between the goal itself and the execution of it.","db_value":"performance_stagnation","sort_factor":3,"coaching_priority":"Clarity, structure, accountability","tradeoff_statement":"Capability isn't the gap. Something between knowing and doing is where the work lives."},"bTHys":{"display":"Alignment Fracture","description":"There's a gap between how you're living and what actually matters to you. You may be performing or surviving — but something feels off at a deeper level. This is where your coaching will focus.","db_value":"alignment_fracture","sort_factor":4,"coaching_priority":"Identity, purpose, habit work","tradeoff_statement":"You may be performing or surviving — but something off at a deeper level is driving all the friction."},"bTHyw":{"display":"Optimization Ready","description":"You're operating from a solid foundation across all three dimensions. The work now is about expanding your capacity, refining your edge, and sustaining what you've built.","prompt":"This person's classification is Optimization Ready. All three dimensions are solid. They are operating from a stable foundation and are ready for growth. The pattern you are working with: a person who has done real work to get here. The risk now is not breakdown — it is staying comfortable when they are genuinely capable of more. The coaching priority is expansion. Push them. Challenge the assumptions they have stopped questioning. Ask them to name the thing they are not saying. Help them identify where they are playing it safe in a way that is costing them something. What this person most needs from you: a coaching presence that matches their level. Do not over-validate. Do not soften unnecessarily. They are ready for direct engagement and they will feel the lack of it if you stay too soft. Ask them about the edge. \"Where are you deliberately staying in your comfort zone right now?\" \"What would you do if you were operating without the fear of getting it wrong?\" \"What's the version of you that's two levels ahead — what does that person do differently?\" Watch for: high performance being used as a reason not to look at what is still unexamined, and contentment being confused with satisfaction.","db_value":"optimization_ready","sort_factor":5,"coaching_priority":"Expansion, growth, edge refinement","tradeoff_statement":"Your foundation is solid. The risk now is staying comfortable when you're genuinely ready to stretch."},"bTHyx":{"display":"Comfortable Plateau","description":"Things are okay — and okay took real work to get to. But something brought you here, which usually means part of you knows that okay isn't quite enough. Your coaching will gently surface what you've been sitting with.","db_value":"comfortable_plateau","sort_factor":6,"coaching_priority":"Gentle surface — what okay is costing","tradeoff_statement":"Okay took real work to get to. But something brought you here — and okay usually has a quiet cost."},"bTHyy":{"display":"Building Momentum","description":"You're in a transition zone — not in crisis, but not yet where you want to be. You know you want more and you're ready to work for it. Your coaching will focus on building consistency and identifying highest-leverage areas for growth.","db_value":"building_momentum","sort_factor":7,"coaching_priority":"Consistency and highest-leverage action","tradeoff_statement":"You're in the transition zone. Not in crisis, not yet where you want to be. The gap is consistency."}},"attributes":{"description":{"display":"description","value":"text","creation_source":"editor"},"prompt":{"display":"prompt","value":"text","creation_source":"editor"},"coaching_priority":{"display":"coaching_priority","value":"text","creation_source":"editor"},"tradeoff_statement":{"display":"tradeoff_statement","value":"text","creation_source":"editor"}},"creation_source":"editor"},"customer_state_os":{"display":"Customer State OS","deleted":true,"values":{"bTHoW":{"display":"wired","db_value":"wired","sort_factor":1},"bTHoX":{"display":"regulated","db_value":"regulated","sort_factor":2},"bTHoY":{"display":"depleted","db_value":"depleted","sort_factor":3},"bTHoc":{"display":"shut_down","db_value":"shut_down","sort_factor":4},"bTHod":{"display":"strong","db_value":"strong","sort_factor":5},"bTHoe":{"display":"moderate","db_value":"moderate","sort_factor":6},"bTHoi":{"display":"low","db_value":"low","sort_factor":7}},"creation_source":"editor"},"customer_pillar_os":{"display":"Customer Pillar OS","values":{"bTHQE":{"display":"emotional","description":"Stress, relationships, grief, confidence, boundaries","label":"Emotional well-being","db_value":"emotional","sort_factor":1},"bTHQF":{"display":"professional","description":"Career, leadership, growth, productivity, burnout at work","label":"Professional","db_value":"professional","sort_factor":2},"bTHQG":{"display":"health","description":"Habits, recovery, sobriety, energy, daily routines","label":"Health & wellness","db_value":"health","sort_factor":3}},"attributes":{"description":{"display":"description","value":"text","creation_source":"editor"},"label":{"display":"label","value":"text","creation_source":"editor"}},"creation_source":"editor"},"onboarding_step_os":{"display":"Onboarding Step OS","values":{"bTHHu":{"display":"Welcome","body":"This isn't a test. It's a way for Uncloud360 to understand how you operate under pressure — so your coaching actually fits your life. The assessment takes about 10 minutes. Your answers shape your personalized dashboard, coaching tone, and the paths recommended for you. You can update your profile anytime as things change.","db_value":"welcome","headline":"Welcome. Let's understand how you're really doing.","sort_factor":1},"bTHHv":{"display":"Name","body":"This is how your AI coach will address you throughout your sessions.","number":1,"db_value":"name","headline":"What should we call you?","sort_factor":2},"bTHHw":{"display":"Role","body":"This helps us make sure the questions feel relevant to your actual life.","number":2,"db_value":"role","headline":"How would you describe your current primary role?","sort_factor":3},"bTHIA":{"display":"Pillar","body":"You can access all three areas anytime. This just tells us where to focus first.","number":3,"db_value":"pillar","headline":"Where is life feeling heaviest right now, [Name]?","sort_factor":4},"bTHIB":{"display":"Stability","body":"There are no right or wrong answers. Answer based on the past two to three weeks.","number":4,"db_value":"stability","headline":"How you're holding up emotionally","sort_factor":5},"bTHIC":{"display":"Performance","number":5,"db_value":"performance","sort_factor":6},"bTHIG":{"display":"Alignment","body":"This looks at how your daily life matches who you are and where you want to go.","number":6,"db_value":"alignment","headline":"How aligned your life feels","sort_factor":7},"bTHIH":{"display":"Orientation","number":7,"db_value":"orientation","headline":"When you think about where you are right now, which feels most true?","sort_factor":8},"bTHII":{"display":"Load Signals","body":"These help your coach understand your context. Be honest, not optimistic.","number":8,"db_value":"load_signals","headline":"Let's understand what's pressing on you right now, [Name].\n","sort_factor":9},"bTHIM":{"display":"State Signals","body":"This isn't about fitness. It's about how your system is responding to what you're carrying.","number":9,"db_value":"state_signals","headline":"How is your body holding everything right now, [Name]?","sort_factor":10},"bTHIN":{"display":"Behavioral Pattern","body":"There is no right answer. The most useful answer is the most honest one.","number":10,"db_value":"behavioral_pattern","headline":"Last two questions, [Name] — these are about how you actually respond.","sort_factor":11},"bTHIO":{"display":"Health & Wellness Flags","body":"Completely optional and entirely private. Select any that apply.","number":11,"db_value":"health___wellness_flags","headline":"Is there anything in your health journey — or life situation — you'd like your coach to be aware of?","sort_factor":12},"bTIFm":{"display":"Results","number":12,"db_value":"results","sort_factor":13}},"attributes":{"body":{"display":"body","value":"text","creation_source":"editor"},"number":{"display":"index","value":"number","creation_source":"editor"},"headline":{"display":"headline","value":"text","creation_source":"editor"}},"creation_source":"editor"},"prior_support_type":{"display":"Prior Support Type OS","values":{"bTIOO":{"display":"therapy","db_value":"bTINQ","sort_factor":1},"bTIOP":{"display":"coaching","db_value":"bTINR","sort_factor":2},"bTIOQ":{"display":"none","db_value":"bTINS","sort_factor":3},"bTIOU":{"display":"other","db_value":"bTINT","sort_factor":4}}},"ai_coaching_mode_os":{"display":"AI Coaching Mode OS","values":{"bTIEC":{"display":"protector","prompt":"This person has flagged something sensitive — recovery, grief, or significant life disruption. Protector mode overrides all other coaching modes. It does not stack or share priority. It runs alone. Your pace is the slowest it ever gets. Your empathy is at its highest. You never push. You never close loops prematurely. You never introduce urgency. If recovery is active: You do not raise substance use, sobriety, or recovery as a topic unless this person opens that door themselves. If they do open it, you follow their lead with warmth, zero judgment, and zero agenda. You do not probe for details. You do not treat their recovery as a problem to be solved in this session. You hold it as context that informs everything about how you show up — not as a topic to address. If grief is active: You do not rush them toward acceptance, meaning-making, or silver linings. Grief is not a problem to be solved. You hold the weight of it with them. You do not minimize it, reframe it, or try to move past it faster than they are ready to move. In both cases: You ask questions that create space, not questions that create tasks. \"What feels most true for you right now?\" is the right kind of question. \"What do you want to do about it?\" is not. You are a safe presence in an unsafe feeling moment. That is the whole job right now.","db_value":"protector","sort_factor":1},"bTIEG":{"display":"stabilizer","prompt":"This person is operating at or near their capacity floor. They do not have reserves for optimization, insight work, or goal-setting right now. Your only job in this session is to be a stable, grounding presence. Stabilization comes before everything else. Not growth. Not clarity. Not action. Stability. Your pace is slow. Your sentences are short. Your energy is calm and unhurried. You validate before you do anything else — not with empty affirmation, but with genuine acknowledgment that what this person is experiencing is real and makes sense. Do not set goals in this session. Do not use productivity language. Do not ask \"what do you want to work on?\" Do not offer a list of options. Do not create tasks or next steps unless the user explicitly asks for them. Ask simple, grounding questions — questions about the body, the present moment, what feels most present right now. Not questions about the future, about solutions, or about what needs to change. If the person pushes toward problem-solving or goal-setting, meet them with warmth but redirect gently: this session is about settling, not solving. The tradeoff statement for this user is: [TRADEOFF_STATEMENT]. Do not surface it in this session — they do not have the capacity to process cost analysis right now. Hold it for a later session.","db_value":"stabilizer","sort_factor":2},"bTIEH":{"display":"simplifier","prompt":"This person's cognitive load is high. Their mental bandwidth is significantly reduced. The session itself must not add to the cognitive demand they are already carrying. When Simplifier is active, apply these rules on top of whatever primary mode is running: Keep responses shorter than usual — two paragraphs maximum when possible. Use the simplest possible language. No complex sentences. No multi-part ideas in a single statement. One idea at a time. Ask only the most essential question — not the most interesting one. The question should require minimal cognitive effort to answer. \"How does that feel?\" is better than \"What do you think is driving that pattern?\" Do not offer options or choices. Choice requires cognitive bandwidth this person does not currently have. If a decision needs to be made, guide them toward one clear, small thing rather than presenting alternatives. If the person seems to be getting lost or looping, bring them back gently to the simplest possible anchor: what is happening right now, in this moment.","db_value":"simplifier","sort_factor":3},"bTIEI":{"display":"rebuilder","prompt":"This person is experiencing a gap between who they are and how they are living. This is not a performance problem. It is an identity and meaning problem. The coaching here goes deeper than behavior. Your work in this session is excavation, not direction. You are helping this person find something — a thread, a value, a sense of what actually matters — not handing them a plan. Ask questions that go beneath the surface. \"What does that mean to you?\" is better than \"What are you going to do about it?\" Sit with what they say before moving to the next question. Reflect back what you are hearing before asking anything new. You use fewer answers and more questions in this mode than in any other. If you find yourself giving advice, stop. The insight needs to come from them, not from you. Your pace is reflective and unhurried. You are not trying to reach a conclusion by the end of this session. You are helping this person feel less alone in a question they have been carrying, and perhaps begin to articulate it more clearly. The tradeoff statement for this user is: [TRADEOFF_STATEMENT]. You may surface this gently when the moment is right — not as a confrontation, but as a mirror.","db_value":"rebuilder","sort_factor":4},"bTIEM":{"display":"strategist","prompt":"This person is in a stable, growth-ready state. They have capacity. They are oriented toward progress. This session can be direct, challenging, and forward-focused. You are not here to validate — that is not what this person needs right now. You are here to think alongside them at a high level, challenge assumptions, name what you see in the data, and help them identify the highest-leverage area for growth. You ask direct questions. \"What are you actually willing to change?\" is fair game. \"Where do you know you're settling?\" is fair game. You do not soften your observations unnecessarily. If you see something worth naming, name it clearly and let them respond. You use the data. If their scores, pressure profile, or behavioral fingerprint reveal something relevant, you can reference it naturally. \"Your execution scores are strong but your confidence scores are notably lower — what's that about?\" is an appropriate observation in this mode. Ask for commitment. At some point in this session, ask: what is one thing you are willing to actually do differently? Hold the line on specificity. Vague commitments are not commitments. Your energy is engaged and challenging — not harsh, not aggressive, but genuinely interested in what this person is capable of and willing to say so.","db_value":"strategist","sort_factor":5}},"attributes":{"prompt":{"display":"prompt","value":"text","creation_source":"editor"}},"creation_source":"editor"},"conflict_pattern_os":{"display":"Conflict Pattern OS","values":{"bTIMM":{"display":"avoid","db_value":"bTIMF","sort_factor":1},"bTIMQ":{"display":"escalate","db_value":"bTIMG","sort_factor":2},"bTIMR":{"display":"collapse","db_value":"bTIMK","sort_factor":3},"bTIMS":{"display":"engage","db_value":"bTIML","sort_factor":4}}},"perception_gap_flag":{"display":"Perception Gap Flag OS","values":{"bTIQI":{"display":"none","db_value":"none","sort_factor":1},"bTIQM":{"display":"under_recognition","db_value":"under_recognition","sort_factor":2},"bTIQN":{"display":"overextension","db_value":"overextension","sort_factor":3},"bTIQO":{"display":"misalignment","db_value":"misalignment","sort_factor":4}},"creation_source":"editor"},"pressure_profile_os":{"display":"Pressure Profile OS","deleted":true,"values":{"bTIAk":{"display":"Cognitive Overload + Wired Nervous System","db_value":"cognitive_overload___wired_nervous_system","sort_factor":1},"bTIAo":{"display":"Cognitive Overload + Depleted","db_value":"cognitive_overload___depleted","sort_factor":2},"bTIAp":{"display":"Relational Strain + [state value]","db_value":"relational_strain____state_value_","sort_factor":3},"bTIAq":{"display":"Logistical Overwhelm + [state value]","db_value":"logistical_overwhelm____state_value_","sort_factor":4},"bTIAu":{"display":"Financial Stress + [state value]","db_value":"financial_stress____state_value_","sort_factor":5},"bTIAv":{"display":"Low Pressure / Regulated","db_value":"low_pressure___regulated","sort_factor":6}},"creation_source":"editor"},"ai_coaching_mode_os0":{"display":"AI Coaching Mode OS copy","deleted":true,"values":{"bTINA":{"display":"protector","db_value":"bTIEC","sort_factor":1},"bTINB":{"display":"stabilizer","db_value":"bTIEG","sort_factor":2},"bTINC":{"display":"simplifier","db_value":"bTIEH","sort_factor":3},"bTING":{"display":"rebuilder","db_value":"bTIEI","sort_factor":4},"bTINH":{"display":"strategist","db_value":"bTIEM","sort_factor":5}},"creation_source":"editor"},"ai_coaching_mode_os1":{"display":"AI Coaching Mode OS copy","deleted":true,"values":{"bTINI":{"display":"protector","db_value":"bTIEC","sort_factor":1},"bTINM":{"display":"stabilizer","db_value":"bTIEG","sort_factor":2},"bTINN":{"display":"simplifier","db_value":"bTIEH","sort_factor":3},"bTINO":{"display":"rebuilder","db_value":"bTIEI","sort_factor":4},"bTINS":{"display":"strategist","db_value":"bTIEM","sort_factor":5}},"creation_source":"editor"},"ai_coaching_mode_os2":{"display":"AI Coaching Mode OS copy","deleted":true,"values":{"bTINT":{"display":"protector","db_value":"bTIEC","sort_factor":1},"bTINU":{"display":"stabilizer","db_value":"bTIEG","sort_factor":2},"bTINY":{"display":"simplifier","db_value":"bTIEH","sort_factor":3},"bTINZ":{"display":"rebuilder","db_value":"bTIEI","sort_factor":4},"bTINa":{"display":"strategist","db_value":"bTIEM","sort_factor":5}},"creation_source":"editor"},"ai_coaching_mode_os3":{"display":"AI Coaching Mode OS copy","deleted":true,"values":{"bTINe":{"display":"protector","db_value":"bTIEC","sort_factor":1},"bTINf":{"display":"stabilizer","db_value":"bTIEG","sort_factor":2},"bTINg":{"display":"simplifier","db_value":"bTIEH","sort_factor":3},"bTINk":{"display":"rebuilder","db_value":"bTIEI","sort_factor":4},"bTINl":{"display":"strategist","db_value":"bTIEM","sort_factor":5}},"creation_source":"editor"},"attachment_signal_os":{"display":"Attachment Signal OS","values":{"bTIMF":{"display":"secure","db_value":"secure","sort_factor":1},"bTIMG":{"display":"anxious","db_value":"anxious","sort_factor":2},"bTIMK":{"display":"avoidant","db_value":"avoidant","sort_factor":3},"bTIML":{"display":"disorganized","db_value":"disorganized","sort_factor":4}},"creation_source":"editor"},"sleep_quality_signal":{"display":"Sleep Quality Signal OS","values":{"bTIOs":{"display":"good","db_value":"bTIOF","sort_factor":1},"bTIOt":{"display":"fair","db_value":"bTIOG","sort_factor":2},"bTIOu":{"display":"poor","db_value":"bTIOH","sort_factor":3}}},"attachment_signal_os0":{"display":"Attachment Signal OS copy","deleted":true,"values":{"bTIMi":{"display":"secure","db_value":"bTIMF","sort_factor":1},"bTIMj":{"display":"anxious","db_value":"bTIMG","sort_factor":2},"bTIMk":{"display":"avoidant","db_value":"bTIMK","sort_factor":3},"bTIMo":{"display":"disorganized","db_value":"bTIML","sort_factor":4}},"creation_source":"editor"},"attachment_signal_os1":{"display":"Attachment Signal OS copy","deleted":true,"values":{"bTIMp":{"display":"secure","db_value":"bTIMF","sort_factor":1},"bTIMq":{"display":"anxious","db_value":"bTIMG","sort_factor":2},"bTIMu":{"display":"avoidant","db_value":"bTIMK","sort_factor":3},"bTIMv":{"display":"disorganized","db_value":"bTIML","sort_factor":4}},"creation_source":"editor"},"hormonal_context_flag":{"display":"Hormonal Context Flag OS","deleted":true,"values":{"bTIOy":{"display":"yes","db_value":"bTIOI","sort_factor":1},"bTIOz":{"display":"no","db_value":"bTIOJ","sort_factor":2}}},"hormonal_context_type":{"display":"Hormonal Context Type OS","values":{"bTIPA":{"display":"perimenopause","db_value":"bTIOK","sort_factor":1},"bTIPE":{"display":"postpartum","db_value":"bTIOL","sort_factor":2},"bTIPF":{"display":"other","db_value":"bTIOM","sort_factor":3},"bTIPG":{"display":"none","db_value":"bTION","sort_factor":4}}},"intimacy_safety_level":{"display":"Intimacy Safety Level OS","values":{"bTINq":{"display":"safe","db_value":"bTINE","sort_factor":1},"bTINr":{"display":"mixed","db_value":"bTINF","sort_factor":2},"bTINs":{"display":"unsafe","db_value":"bTING","sort_factor":3},"bTINw":{"display":"absent","db_value":"bTINH","sort_factor":4}}},"state_energy_level_os":{"display":"State Energy Level OS","values":{"bTIBk":{"display":"strong","db_value":"strong","sort_factor":1},"bTIBl":{"display":"moderate","db_value":"moderate","sort_factor":2},"bTIBm":{"display":"low","db_value":"low","sort_factor":3},"bTIBq":{"display":"depleted","db_value":"depleted","sort_factor":4}},"creation_source":"editor"},"workload_intensity_os":{"display":"Load Intensity OS","values":{"bTHmB":{"display":"Low","db_value":"low","sort_factor":1},"bTHmC":{"display":"Medium","db_value":"medium","sort_factor":2},"bTHmG":{"display":"High","db_value":"high","sort_factor":3,"cognitive_prompt":"This person's cognitive load is high. Their mental bandwidth is reduced. Do not add to the cognitive demand of this session. Use the simplest possible language. Ask only the most essential question. One idea at a time. If they seem overwhelmed by a question, simplify it before repeating it.","financial_prompt":"This person's financial load is high. Financial stress is a real and present part of their daily experience. Acknowledge this directly and without minimizing it when it is relevant. Do not recommend solutions that cost money. Do not frame financial stress as a mindset problem — it has real, practical dimensions. If financial anxiety is affecting their cognitive bandwidth, factor that into your pacing.","relational_prompt":"This person's relational load is high. Key relationships are a significant source of stress right now. Do not assume their relationships are resources — for this person, they may be costs. If relationships come up, explore them without assuming support exists. Boundary work and communication coaching are relevant here when the timing is right.","environmental_prompt":"This person's environmental load is high. Logistics, time pressure, and practical demands are significant. Ground advice in what is actually possible given these constraints. Do not recommend solutions that require significant time, money, or energy they do not currently have. Prioritization and structure coaching is relevant when they are ready for it."}},"attributes":{"cognitive_prompt":{"display":"cognitive_prompt","value":"text","creation_source":"editor"},"financial_prompt":{"display":"financial_prompt","value":"text","creation_source":"editor"},"relational_prompt":{"display":"relational_prompt","value":"text","creation_source":"editor"},"environmental_prompt":{"display":"environmental_prompt","value":"text","creation_source":"editor"}},"creation_source":"editor"},"ai_confidence_level_os":{"display":"AI Confidence Level OS","values":{"bTIFK":{"display":"exploratory","db_value":"exploratory","sort_factor":1,"gidget_behavior":"Curious questions, avoids strong assumptions, actively gathers missing context in session","modules_completed_count_max":0,"modules_completed_count_min":0},"bTIFO":{"display":"exploratory+","db_value":"exploratory_","sort_factor":2,"gidget_behavior":"Makes informed observations, notes gaps, probes missing layers","modules_completed_count_max":2,"modules_completed_count_min":1},"bTIFP":{"display":"guided","db_value":"guided","sort_factor":3,"gidget_behavior":"Informed suggestions, pattern recognition, confronts gently with evidence","modules_completed_count_max":4,"modules_completed_count_min":3},"bTIFQ":{"display":"direct","db_value":"direct","sort_factor":4,"gidget_behavior":"Full pattern recognition, direct interventions, confident challenge when appropriate","modules_completed_count_max":6,"modules_completed_count_min":5}},"attributes":{"gidget_behavior":{"display":"gidget_behavior","value":"text","creation_source":"editor"},"modules_completed_count_max":{"display":"modules_count_max","value":"number","creation_source":"editor"},"modules_completed_count_min":{"display":"modules_count_min","value":"number","creation_source":"editor"}},"creation_source":"editor"},"financial_agency_level":{"display":"Financial Agency Level OS","values":{"bTIOi":{"display":"in_control","db_value":"bTIOB","sort_factor":1},"bTIOm":{"display":"somewhat","db_value":"bTIOC","sort_factor":2},"bTIOn":{"display":"little","db_value":"bTIOD","sort_factor":3},"bTIOo":{"display":"none","db_value":"bTIOE","sort_factor":4}}},"path_enrollment_status":{"display":"Path Enrollment Status OS","values":{"bTIqc":{"display":"active","db_value":"active","sort_factor":1},"bTIqd":{"display":"paused","db_value":"paused","sort_factor":2},"bTIqe":{"display":"completed","db_value":"completed","sort_factor":3},"bTIqi":{"display":"abandoned","db_value":"abandoned","sort_factor":4}},"creation_source":"editor"},"financial_anxiety_level":{"display":"Financial Anxiety Level OS","values":{"bTIOc":{"display":"low","db_value":"bTINY","sort_factor":1},"bTIOg":{"display":"medium","db_value":"bTINZ","sort_factor":2},"bTIOh":{"display":"high","db_value":"bTIOA","sort_factor":3}}},"state_nervous_system_os":{"display":"State Nervous System OS","values":{"bTIBa":{"display":"Wired","prompt":"This person's nervous system is wired — anxious, on edge, braced. Open with regulation, not direction. Calm language. No urgency. Do not introduce challenge or stretch until regulation has occurred. The goal of the first part of this session is to lower the activation level, not to coach toward growth.","db_value":"wired","sort_factor":1},"bTIBe":{"display":"Regulated","prompt":"This person's nervous system is regulated. Full coaching range available. Challenge, stretch, and direct observation are all appropriate. Match their stability with presence and engagement.","db_value":"regulated","sort_factor":2},"bTIBf":{"display":"Depleted","prompt":"This person's nervous system is depleted — exhausted, flat, running on empty. Gentle only. Low demand. Validate first, always. No stretch goals. No big asks. A micro-win is the most ambitious outcome available in this session. Meet them exactly where they are.","db_value":"depleted","sort_factor":3},"bTIBg":{"display":"Shut Down","prompt":"This person's nervous system is shut down — numb, disconnected, going through the motions. Re-engagement is the only goal. Tiny steps. High acknowledgment for any forward motion at all. Never push through shutdown. The work here is gently bringing them back into contact with themselves.","db_value":"shut_down","sort_factor":4}},"attributes":{"prompt":{"display":"prompt","value":"text","creation_source":"editor"}},"creation_source":"editor"},"trauma_activation_level":{"display":"Trauma Activation Level OS","values":{"bTINx":{"display":"low","db_value":"bTINI","sort_factor":1},"bTINy":{"display":"present","db_value":"bTINJ","sort_factor":2},"bTIOC":{"display":"active","db_value":"bTINK","sort_factor":3},"bTIOD":{"display":"unsure","db_value":"bTINL","sort_factor":4}}},"customer_state_signal_os":{"display":"Customer State Signal Question OS","values":{"bTHoR":{"display":"Which best describes how your nervous system feels most of the time right now?","index":1,"db_value":"which_best_describes_how_your_nervous_system_feels_most_of_the_time_right_now_","sort_factor":1},"bTHoS":{"display":"How would you describe your energy levels over the past two to three weeks?","index":2,"db_value":"how_would_you_describe_your_energy_levels_over_the_past_two_to_three_weeks_","sort_factor":2}},"attributes":{"index":{"display":"index","value":"number","creation_source":"editor"}},"creation_source":"editor"},"customers_load_signal_os":{"display":"Customer Load Signal Question OS","values":{"bTHlu":{"display":"How much mental noise are you dealing with — racing thoughts, rumination, decision fatigue?","index":1,"db_value":"how_much_mental_noise_are_you_dealing_with___racing_thoughts__rumination__decision_fatigue_","sort_factor":1},"bTHlv":{"display":"How much are your relationships adding to your stress right now?","index":2,"db_value":"how_much_are_your_relationships_adding_to_your_stress_right_now_","sort_factor":2},"bTHlw":{"display":"How much pressure are logistics and time creating — schedule, responsibilities, deadlines?","index":3,"db_value":"how_much_pressure_are_logistics_and_time_creating___schedule__responsibilities__deadlines_","sort_factor":3},"bTHmA":{"display":"How much is financial stress affecting your day-to-day mental state?","index":4,"db_value":"how_much_is_financial_stress_affecting_your_day_to_day_mental_state_","sort_factor":4}},"attributes":{"index":{"display":"index","value":"number","creation_source":"editor"}},"creation_source":"editor"},"spiritual_framework_type":{"display":"Spiritual Framework Type OS","values":{"bTIPe":{"display":"active","db_value":"bTIPD","sort_factor":1},"bTIPi":{"display":"background","db_value":"bTIPE","sort_factor":2},"bTIPj":{"display":"complicated","db_value":"bTIPF","sort_factor":3},"bTIPk":{"display":"none","db_value":"bTIPG","sort_factor":4},"bTIPo":{"display":"exploring","db_value":"bTIPH","sort_factor":5}}},"substance_pattern_signal":{"display":"Substance Pattern Signal OS","values":{"bTIPR":{"display":"none","db_value":"bTIOU","sort_factor":1},"bTIPS":{"display":"managed","db_value":"bTIOV","sort_factor":2},"bTIPW":{"display":"concerning","db_value":"bTIOW","sort_factor":3}}},"support_seeking_capacity":{"display":"Support Seeking Capacity OS","values":{"bTIMW":{"display":"high","db_value":"bTINA","sort_factor":1},"bTIMX":{"display":"medium","db_value":"bTINB","sort_factor":2},"bTIMY":{"display":"low","db_value":"bTINC","sort_factor":3},"bTIMc":{"display":"blocked","db_value":"bTIND","sort_factor":4}}},"financial_stability_signal":{"display":"Financial Stability Signal OS","values":{"bTIOV":{"display":"stable","db_value":"bTINU","sort_factor":1},"bTIOW":{"display":"strained","db_value":"bTINV","sort_factor":2},"bTIOa":{"display":"crisis","db_value":"bTINW","sort_factor":3},"bTIOb":{"display":"rebuilding","db_value":"bTINX","sort_factor":4}}},"identity_narrative_type_os":{"display":"Identity Narrative Type OS","values":{"bTILn":{"display":"growth","db_value":"growth","sort_factor":1},"bTILo":{"display":"fixed","db_value":"fixed","sort_factor":2},"bTILs":{"display":"mixed","db_value":"mixed","sort_factor":3},"bTILt":{"display":"unclear","db_value":"unclear","sort_factor":4}},"creation_source":"editor"},"customer_health_question_os":{"display":"Customer Health Flags OS","values":{"bTHuc":{"display":"I'm in recovery from substance use","db_value":"i_m_in_recovery_from_substance_use","sort_factor":1},"bTHud":{"display":"I'm navigating a signific